{
  "name": "build-utils",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/build-utils/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build-types": {
      "dependsOn": [
        "^build"
      ],
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/build-utils",
        "main": "libs/build-utils/src/index.ts",
        "tsConfig": "libs/build-utils/tsconfig.lib.json",
        "generatePackageJson": false
      }
    },
        "build": {
      "dependsOn": [
        "build-types",
        "^build"
      ],
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/build-utils",
        "main": "libs/build-utils/src/index.ts",
        "tsConfig": "libs/build-utils/tsconfig.lib.json",
        "bundle": true,
        "platform": "node",
        "format": [
          "esm",
          "cjs"
        ],
        "outputFileName": "dist/index.js",
        "declaration": false,
        "skipTypeCheck": true,
        "deleteOutputPath": false,
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        },
        "assets": [
          "libs/build-utils/*.md",
          {
            "input": "./libs/build-utils",
            "glob": "migrations.json",
            "output": "."
          }
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/build-utils/jest.config.cts",
        "codeCoverage": true,
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "release": {
      "executor": "@onecx/release:update-build-publish",
      "options": {
        "buildTarget": "build"
      }
    }
  }
}
