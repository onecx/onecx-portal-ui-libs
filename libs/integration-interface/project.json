{
  "name": "integration-interface",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/integration-interface/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build-types": {
      "dependsOn": [
        "^build"
      ],
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/integration-interface",
        "main": "libs/integration-interface/src/index.ts",
        "tsConfig": "libs/integration-interface/tsconfig.lib.json",
        "generatePackageJson": false
      }
    },
    "generate-theme-json-schema": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx -y tsx libs/integration-interface/scripts/generate-json-schema.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "build-lib": {
      "dependsOn": [
        "build-types",
        "^build"
      ],
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/integration-interface",
        "main": "libs/integration-interface/src/index.ts",
        "tsConfig": "libs/integration-interface/tsconfig.lib.json",
        "bundle": true,
        "platform": "browser",
        "format": [
          "esm",
          "cjs"
        ],
        "outputFileName": "dist/index.js",
        "declaration": false,
        "skipTypeCheck": true,
        "deleteOutputPath": false,
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          }
        },
        "assets": [
          "libs/integration-interface/*.md",
          {
            "input": "./libs/integration-interface",
            "glob": "migrations.json",
            "output": "."
          }
        ]
      }
    },
    "build": {
      "dependsOn": [
        "build-lib",
        "generate-theme-json-schema"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "libs/integration-interface/**/*.ts",
          "libs/integration-interface/package.json"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/integration-interface/jest.config.ts",
        "codeCoverage": true,
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "release": {
      "executor": "@onecx/release:update-build-publish",
      "options": {
        "buildTarget": "build"
      }
    }
  }
}
